# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored; `.env.example` stays committed as documentation.

# --- Database (Supabase) ---
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JWT ---
# Generate with: openssl rand -base64 48
# Must be at least 32 bytes after base64-decoding.
JWT_SECRET=
# Optional. Defaults to 86400 (24h) if omitted.
JWT_TTL_SECONDS=86400

# --- Google OAuth ---
# From Google Cloud Console > APIs & Services > Credentials.
GOOGLE_WEB_CLIENT_ID=
# Optional: only needed if you create iOS/Android OAuth clients.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# --- GitHub OAuth ---
# From github.com/settings/developers > OAuth Apps.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- CORS ---
# Comma-separated origins allowed to call this backend.
# Defaults to http://localhost:8081,http://localhost:19006 if omitted.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
